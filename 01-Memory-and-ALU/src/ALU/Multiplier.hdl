    HalfAdder(a=px15x4, b=px14x5, sum=sBx19, carry=cBx20);
    Or(a=px15x5, b=false, out=sBx20);

    // Grp C (Rows 6,7,8 - weights 6 to 23)
    Or(a=px0x6, b=false, out=sCx6);
    HalfAdder(a=px1x6, b=px0x7, sum=sCx7, carry=cCx8);
    FullAdder(a=px2x6, b=px1x7, c=px0x8, sum=sCx8, carry=cCx9);
