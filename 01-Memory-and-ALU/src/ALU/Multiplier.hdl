    FullAdder(a=sAx14, b=cAx14, c=sBx14, sum=sFx14, carry=cFx15);
    FullAdder(a=sAx15, b=cAx15, c=sBx15, sum=sFx15, carry=cFx16);
    FullAdder(a=sAx16, b=cAx16, c=sBx16, sum=sFx16, carry=cFx17);
    FullAdder(a=sAx17, b=cAx17, c=sBx17, sum=sFx17, carry=cFx18);
    Or(a=sBx18, b=false, out=sFx18);
    Or(a=sBx19, b=false, out=sFx19);
    Or(a=sBx20, b=false, out=sFx20);

    // Grp G (cB:5..20, sC:6..23, cC:8..23)
    Or(a=cBx5, b=false, out=sGx5);
    HalfAdder(a=cBx6, b=sCx6, sum=sGx6, carry=cGx7);
    HalfAdder(a=cBx7, b=sCx7, sum=sGx7, carry=cGx8);
    FullAdder(a=cBx8, b=sCx8, c=cCx8, sum=sGx8, carry=cGx9);
    FullAdder(a=cBx9, b=sCx9, c=cCx9, sum=sGx9, carry=cGx10);
    FullAdder(a=cBx10, b=sCx10, c=cCx10, sum=sGx10, carry=cGx11);
    FullAdder(a=cBx11, b=sCx11, c=cCx11, sum=sGx11, carry=cGx12);
    FullAdder(a=cBx12, b=sCx12, c=cCx12, sum=sGx12, carry=cGx13);
    FullAdder(a=cBx13, b=sCx13, c=cCx13, sum=sGx13, carry=cGx14);
    FullAdder(a=cBx14, b=sCx14, c=cCx14, sum=sGx14, carry=cGx15);
    FullAdder(a=cBx15, b=sCx15, c=cCx15, sum=sGx15, carry=cGx16);
    FullAdder(a=cBx16, b=sCx16, c=cCx16, sum=sGx16, carry=cGx17);
    FullAdder(a=cBx17, b=sCx17, c=cCx17, sum=sGx17, carry=cGx18);
    FullAdder(a=cBx18, b=sCx18, c=cCx18, sum=sGx18, carry=cGx19);
    FullAdder(a=cBx19, b=sCx19, c=cCx19, sum=sGx19, carry=cGx20);
    FullAdder(a=cBx20, b=sCx20, c=cCx20, sum=sGx20, carry=cGx21);
    HalfAdder(a=sCx21, b=cCx21, sum=sGx21, carry=cGx22);
    HalfAdder(a=sCx22, b=cCx22, sum=sGx22, carry=cGx23);
    HalfAdder(a=sCx23, b=cCx23, sum=sGx23, carry=cGx24);

    // Grp H (sD:9..26, cD:11..26, sE:12..29)
    Or(a=sDx9, b=false, out=sHx9);
    Or(a=sDx10, b=false, out=sHx10);
    HalfAdder(a=sDx11, b=cDx11, sum=sHx11, carry=cHx12);
    FullAdder(a=sDx12, b=cDx12, c=sEx12, sum=sHx12, carry=cHx13);
    FullAdder(a=sDx13, b=cDx13, c=sEx13, sum=sHx13, carry=cHx14);
    FullAdder(a=sDx14, b=cDx14, c=sEx14, sum=sHx14, carry=cHx15);
    FullAdder(a=sDx15, b=cDx15, c=sEx15, sum=sHx15, carry=cHx16);
    FullAdder(a=sDx16, b=cDx16, c=sEx16, sum=sHx16, carry=cHx17);
    FullAdder(a=sDx17, b=cDx17, c=sEx17, sum=sHx17, carry=cHx18);
    FullAdder(a=sDx18, b=cDx18, c=sEx18, sum=sHx18, carry=cHx19);
    FullAdder(a=sDx19, b=cDx19, c=sEx19, sum=sHx19, carry=cHx20);
    FullAdder(a=sDx20, b=cDx20, c=sEx20, sum=sHx20, carry=cHx21);
    FullAdder(a=sDx21, b=cDx21, c=sEx21, sum=sHx21, carry=cHx22);
    FullAdder(a=sDx22, b=cDx22, c=sEx22, sum=sHx22, carry=cHx23);
    FullAdder(a=sDx23, b=cDx23, c=sEx23, sum=sHx23, carry=cHx24);
    FullAdder(a=sDx24, b=cDx24, c=sEx24, sum=sHx24, carry=cHx25);
    FullAdder(a=sDx25, b=cDx25, c=sEx25, sum=sHx25, carry=cHx26);
    FullAdder(a=sDx26, b=cDx26, c=sEx26, sum=sHx26, carry=cHx27);
    Or(a=sEx27, b=false, out=sHx27);
    Or(a=sEx28, b=false, out=sHx28);
    Or(a=sEx29, b=false, out=sHx29);


    
    // Stage 3: 8 rows -> 6 rows
    
    // Grp J (sF:0..20, cF:3..18, sG:5..23)
    Or(a=sFx0, b=false, out=sJx0);
    Or(a=sFx1, b=false, out=sJx1);
    Or(a=sFx2, b=false, out=sJx2);
    HalfAdder(a=sFx3, b=cFx3, sum=sJx3, carry=cJx4);
    HalfAdder(a=sFx4, b=cFx4, sum=sJx4, carry=cJx5);
    FullAdder(a=sFx5, b=cFx5, c=sGx5, sum=sJx5, carry=cJx6);
    FullAdder(a=sFx6, b=cFx6, c=sGx6, sum=sJx6, carry=cJx7);
    FullAdder(a=sFx7, b=cFx7, c=sGx7, sum=sJx7, carry=cJx8);
    FullAdder(a=sFx8, b=cFx8, c=sGx8, sum=sJx8, carry=cJx9);
