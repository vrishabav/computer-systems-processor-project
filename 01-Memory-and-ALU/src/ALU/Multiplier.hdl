    FullAdder(a=px6x9, b=px5x10, c=px4x11, sum=sDx15, carry=cDx16);
    FullAdder(a=px7x9, b=px6x10, c=px5x11, sum=sDx16, carry=cDx17);
    FullAdder(a=px8x9, b=px7x10, c=px6x11, sum=sDx17, carry=cDx18);
    FullAdder(a=px9x9, b=px8x10, c=px7x11, sum=sDx18, carry=cDx19);
    FullAdder(a=px10x9, b=px9x10, c=px8x11, sum=sDx19, carry=cDx20);
    FullAdder(a=px11x9, b=px10x10, c=px9x11, sum=sDx20, carry=cDx21);
    FullAdder(a=px12x9, b=px11x10, c=px10x11, sum=sDx21, carry=cDx22);
