    HalfAdder(a=px15x7, b=px14x8, sum=sCx22, carry=cCx23);
    Or(a=px15x8, b=false, out=sCx23);

    // Grp D (Rows 9,10,11 - weights 9 to 26)
    Or(a=px0x9, b=false, out=sDx9);
    HalfAdder(a=px1x9, b=px0x10, sum=sDx10, carry=cDx11);
    FullAdder(a=px2x9, b=px1x10, c=px0x11, sum=sDx11, carry=cDx12);
    FullAdder(a=px3x9, b=px2x10, c=px1x11, sum=sDx12, carry=cDx13);
    FullAdder(a=px4x9, b=px3x10, c=px2x11, sum=sDx13, carry=cDx14);
