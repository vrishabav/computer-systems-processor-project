    FullAdder(a=sJx20, b=cJx20, c=sKx20, sum=sLx20, carry=cLx21);
    FullAdder(a=sJx21, b=cJx21, c=sKx21, sum=sLx21, carry=cLx22);
    HalfAdder(a=sJx22, b=sKx22, sum=sLx22, carry=cLx23);
    HalfAdder(a=sJx23, b=sKx23, sum=sLx23, carry=cLx24);
    Or(a=sKx24, b=false, out=sLx24); Or(a=sKx25, b=false, out=sLx25);
    Or(a=sKx26, b=false, out=sLx26); Or(a=sKx27, b=false, out=sLx27);
    Or(a=sKx28, b=false, out=sLx28); Or(a=sKx29, b=false, out=sLx29);

    // Grp M (cK:10..28, cE:14..29, sP:15..30)
    Or(a=cKx10, b=false, out=sMx10); Or(a=cKx11, b=false, out=sMx11);
    Or(a=cKx12, b=false, out=sMx12); Or(a=cKx13, b=false, out=sMx13);
    HalfAdder(a=cKx14, b=cEx14, sum=sMx14, carry=cMx15);
    FullAdder(a=cKx15, b=cEx15, c=sPx15, sum=sMx15, carry=cMx16);
    FullAdder(a=cKx16, b=cEx16, c=sPx16, sum=sMx16, carry=cMx17);
    FullAdder(a=cKx17, b=cEx17, c=sPx17, sum=sMx17, carry=cMx18);
    FullAdder(a=cKx18, b=cEx18, c=sPx18, sum=sMx18, carry=cMx19);
    FullAdder(a=cKx19, b=cEx19, c=sPx19, sum=sMx19, carry=cMx20);
