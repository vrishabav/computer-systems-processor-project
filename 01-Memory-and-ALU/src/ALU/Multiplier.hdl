CHIP Multiplier {
    IN a[16], b[16];
    OUT c[32];

    PARTS:
    // Partial Product Generation with 256 ANDs
    // Naming convention: pxixj = a[i] AND b[j], bit-weight = i + j

    // Row 0
    And(a=a[0], b=b[0], out=px0x0); And(a=a[1], b=b[0], out=px1x0); And(a=a[2], b=b[0], out=px2x0); And(a=a[3], b=b[0], out=px3x0);
    And(a=a[4], b=b[0], out=px4x0); And(a=a[5], b=b[0], out=px5x0); And(a=a[6], b=b[0], out=px6x0); And(a=a[7], b=b[0], out=px7x0);
    And(a=a[8], b=b[0], out=px8x0); And(a=a[9], b=b[0], out=px9x0); And(a=a[10], b=b[0], out=px10x0); And(a=a[11], b=b[0], out=px11x0);
    And(a=a[12], b=b[0], out=px12x0); And(a=a[13], b=b[0], out=px13x0); And(a=a[14], b=b[0], out=px14x0); And(a=a[15], b=b[0], out=px15x0);

    // Row 1
    And(a=a[0], b=b[1], out=px0x1); And(a=a[1], b=b[1], out=px1x1); And(a=a[2], b=b[1], out=px2x1); And(a=a[3], b=b[1], out=px3x1);
    And(a=a[4], b=b[1], out=px4x1); And(a=a[5], b=b[1], out=px5x1); And(a=a[6], b=b[1], out=px6x1); And(a=a[7], b=b[1], out=px7x1);
    And(a=a[8], b=b[1], out=px8x1); And(a=a[9], b=b[1], out=px9x1); And(a=a[10], b=b[1], out=px10x1); And(a=a[11], b=b[1], out=px11x1);
    And(a=a[12], b=b[1], out=px12x1); And(a=a[13], b=b[1], out=px13x1); And(a=a[14], b=b[1], out=px14x1); And(a=a[15], b=b[1], out=px15x1);

    // Row 2
    And(a=a[0], b=b[2], out=px0x2); And(a=a[1], b=b[2], out=px1x2); And(a=a[2], b=b[2], out=px2x2); And(a=a[3], b=b[2], out=px3x2);
    And(a=a[4], b=b[2], out=px4x2); And(a=a[5], b=b[2], out=px5x2); And(a=a[6], b=b[2], out=px6x2); And(a=a[7], b=b[2], out=px7x2);
    And(a=a[8], b=b[2], out=px8x2); And(a=a[9], b=b[2], out=px9x2); And(a=a[10], b=b[2], out=px10x2); And(a=a[11], b=b[2], out=px11x2);
    And(a=a[12], b=b[2], out=px12x2); And(a=a[13], b=b[2], out=px13x2); And(a=a[14], b=b[2], out=px14x2); And(a=a[15], b=b[2], out=px15x2);

    // Row 3
    And(a=a[0], b=b[3], out=px0x3); And(a=a[1], b=b[3], out=px1x3); And(a=a[2], b=b[3], out=px2x3); And(a=a[3], b=b[3], out=px3x3);
    And(a=a[4], b=b[3], out=px4x3); And(a=a[5], b=b[3], out=px5x3); And(a=a[6], b=b[3], out=px6x3); And(a=a[7], b=b[3], out=px7x3);
    And(a=a[8], b=b[3], out=px8x3); And(a=a[9], b=b[3], out=px9x3); And(a=a[10], b=b[3], out=px10x3); And(a=a[11], b=b[3], out=px11x3);
    And(a=a[12], b=b[3], out=px12x3); And(a=a[13], b=b[3], out=px13x3); And(a=a[14], b=b[3], out=px14x3); And(a=a[15], b=b[3], out=px15x3);

    // Row 4
    And(a=a[0], b=b[4], out=px0x4); And(a=a[1], b=b[4], out=px1x4); And(a=a[2], b=b[4], out=px2x4); And(a=a[3], b=b[4], out=px3x4);
    And(a=a[4], b=b[4], out=px4x4); And(a=a[5], b=b[4], out=px5x4); And(a=a[6], b=b[4], out=px6x4); And(a=a[7], b=b[4], out=px7x4);
    And(a=a[8], b=b[4], out=px8x4); And(a=a[9], b=b[4], out=px9x4); And(a=a[10], b=b[4], out=px10x4); And(a=a[11], b=b[4], out=px11x4);
    And(a=a[12], b=b[4], out=px12x4); And(a=a[13], b=b[4], out=px13x4); And(a=a[14], b=b[4], out=px14x4); And(a=a[15], b=b[4], out=px15x4);

    // Row 5
    And(a=a[0], b=b[5], out=px0x5); And(a=a[1], b=b[5], out=px1x5); And(a=a[2], b=b[5], out=px2x5); And(a=a[3], b=b[5], out=px3x5);
    And(a=a[4], b=b[5], out=px4x5); And(a=a[5], b=b[5], out=px5x5); And(a=a[6], b=b[5], out=px6x5); And(a=a[7], b=b[5], out=px7x5);
    And(a=a[8], b=b[5], out=px8x5); And(a=a[9], b=b[5], out=px9x5); And(a=a[10], b=b[5], out=px10x5); And(a=a[11], b=b[5], out=px11x5);
    And(a=a[12], b=b[5], out=px12x5); And(a=a[13], b=b[5], out=px13x5); And(a=a[14], b=b[5], out=px14x5); And(a=a[15], b=b[5], out=px15x5);

    // Row 6
    And(a=a[0], b=b[6], out=px0x6); And(a=a[1], b=b[6], out=px1x6); And(a=a[2], b=b[6], out=px2x6); And(a=a[3], b=b[6], out=px3x6);
    And(a=a[4], b=b[6], out=px4x6); And(a=a[5], b=b[6], out=px5x6); And(a=a[6], b=b[6], out=px6x6); And(a=a[7], b=b[6], out=px7x6);
    And(a=a[8], b=b[6], out=px8x6); And(a=a[9], b=b[6], out=px9x6); And(a=a[10], b=b[6], out=px10x6); And(a=a[11], b=b[6], out=px11x6);
    And(a=a[12], b=b[6], out=px12x6); And(a=a[13], b=b[6], out=px13x6); And(a=a[14], b=b[6], out=px14x6); And(a=a[15], b=b[6], out=px15x6);

    // Row 7
    And(a=a[0], b=b[7], out=px0x7); And(a=a[1], b=b[7], out=px1x7); And(a=a[2], b=b[7], out=px2x7); And(a=a[3], b=b[7], out=px3x7);
    And(a=a[4], b=b[7], out=px4x7); And(a=a[5], b=b[7], out=px5x7); And(a=a[6], b=b[7], out=px6x7); And(a=a[7], b=b[7], out=px7x7);
    And(a=a[8], b=b[7], out=px8x7); And(a=a[9], b=b[7], out=px9x7); And(a=a[10], b=b[7], out=px10x7); And(a=a[11], b=b[7], out=px11x7);
    And(a=a[12], b=b[7], out=px12x7); And(a=a[13], b=b[7], out=px13x7); And(a=a[14], b=b[7], out=px14x7); And(a=a[15], b=b[7], out=px15x7);

    // Row 8
    And(a=a[0], b=b[8], out=px0x8); And(a=a[1], b=b[8], out=px1x8); And(a=a[2], b=b[8], out=px2x8); And(a=a[3], b=b[8], out=px3x8);
    And(a=a[4], b=b[8], out=px4x8); And(a=a[5], b=b[8], out=px5x8); And(a=a[6], b=b[8], out=px6x8); And(a=a[7], b=b[8], out=px7x8);
    And(a=a[8], b=b[8], out=px8x8); And(a=a[9], b=b[8], out=px9x8); And(a=a[10], b=b[8], out=px10x8); And(a=a[11], b=b[8], out=px11x8);
    And(a=a[12], b=b[8], out=px12x8); And(a=a[13], b=b[8], out=px13x8); And(a=a[14], b=b[8], out=px14x8); And(a=a[15], b=b[8], out=px15x8);

    // Row 9
    And(a=a[0], b=b[9], out=px0x9); And(a=a[1], b=b[9], out=px1x9); And(a=a[2], b=b[9], out=px2x9); And(a=a[3], b=b[9], out=px3x9);
    And(a=a[4], b=b[9], out=px4x9); And(a=a[5], b=b[9], out=px5x9); And(a=a[6], b=b[9], out=px6x9); And(a=a[7], b=b[9], out=px7x9);
    And(a=a[8], b=b[9], out=px8x9); And(a=a[9], b=b[9], out=px9x9); And(a=a[10], b=b[9], out=px10x9); And(a=a[11], b=b[9], out=px11x9);
    And(a=a[12], b=b[9], out=px12x9); And(a=a[13], b=b[9], out=px13x9); And(a=a[14], b=b[9], out=px14x9); And(a=a[15], b=b[9], out=px15x9);

    // Row 10
    And(a=a[0], b=b[10], out=px0x10); And(a=a[1], b=b[10], out=px1x10); And(a=a[2], b=b[10], out=px2x10); And(a=a[3], b=b[10], out=px3x10);
    And(a=a[4], b=b[10], out=px4x10); And(a=a[5], b=b[10], out=px5x10); And(a=a[6], b=b[10], out=px6x10); And(a=a[7], b=b[10], out=px7x10);
    And(a=a[8], b=b[10], out=px8x10); And(a=a[9], b=b[10], out=px9x10); And(a=a[10], b=b[10], out=px10x10); And(a=a[11], b=b[10], out=px11x10);
    And(a=a[12], b=b[10], out=px12x10); And(a=a[13], b=b[10], out=px13x10); And(a=a[14], b=b[10], out=px14x10); And(a=a[15], b=b[10], out=px15x10);

    // Row 11
    And(a=a[0], b=b[11], out=px0x11); And(a=a[1], b=b[11], out=px1x11); And(a=a[2], b=b[11], out=px2x11); And(a=a[3], b=b[11], out=px3x11);
    And(a=a[4], b=b[11], out=px4x11); And(a=a[5], b=b[11], out=px5x11); And(a=a[6], b=b[11], out=px6x11); And(a=a[7], b=b[11], out=px7x11);
    And(a=a[8], b=b[11], out=px8x11); And(a=a[9], b=b[11], out=px9x11); And(a=a[10], b=b[11], out=px10x11); And(a=a[11], b=b[11], out=px11x11);
    And(a=a[12], b=b[11], out=px12x11); And(a=a[13], b=b[11], out=px13x11); And(a=a[14], b=b[11], out=px14x11); And(a=a[15], b=b[11], out=px15x11);

    // Row 12
    And(a=a[0], b=b[12], out=px0x12); And(a=a[1], b=b[12], out=px1x12); And(a=a[2], b=b[12], out=px2x12); And(a=a[3], b=b[12], out=px3x12);
    And(a=a[4], b=b[12], out=px4x12); And(a=a[5], b=b[12], out=px5x12); And(a=a[6], b=b[12], out=px6x12); And(a=a[7], b=b[12], out=px7x12);
    And(a=a[8], b=b[12], out=px8x12); And(a=a[9], b=b[12], out=px9x12); And(a=a[10], b=b[12], out=px10x12); And(a=a[11], b=b[12], out=px11x12);
    And(a=a[12], b=b[12], out=px12x12); And(a=a[13], b=b[12], out=px13x12); And(a=a[14], b=b[12], out=px14x12); And(a=a[15], b=b[12], out=px15x12);

    // Row 13
    And(a=a[0], b=b[13], out=px0x13); And(a=a[1], b=b[13], out=px1x13); And(a=a[2], b=b[13], out=px2x13); And(a=a[3], b=b[13], out=px3x13);
    And(a=a[4], b=b[13], out=px4x13); And(a=a[5], b=b[13], out=px5x13); And(a=a[6], b=b[13], out=px6x13); And(a=a[7], b=b[13], out=px7x13);
    And(a=a[8], b=b[13], out=px8x13); And(a=a[9], b=b[13], out=px9x13); And(a=a[10], b=b[13], out=px10x13); And(a=a[11], b=b[13], out=px11x13);
    And(a=a[12], b=b[13], out=px12x13); And(a=a[13], b=b[13], out=px13x13); And(a=a[14], b=b[13], out=px14x13); And(a=a[15], b=b[13], out=px15x13);

    // Row 14
    And(a=a[0], b=b[14], out=px0x14); And(a=a[1], b=b[14], out=px1x14); And(a=a[2], b=b[14], out=px2x14); And(a=a[3], b=b[14], out=px3x14);
    And(a=a[4], b=b[14], out=px4x14); And(a=a[5], b=b[14], out=px5x14); And(a=a[6], b=b[14], out=px6x14); And(a=a[7], b=b[14], out=px7x14);
    And(a=a[8], b=b[14], out=px8x14); And(a=a[9], b=b[14], out=px9x14); And(a=a[10], b=b[14], out=px10x14); And(a=a[11], b=b[14], out=px11x14);
    And(a=a[12], b=b[14], out=px12x14); And(a=a[13], b=b[14], out=px13x14); And(a=a[14], b=b[14], out=px14x14); And(a=a[15], b=b[14], out=px15x14);

    // Row 15
    And(a=a[0], b=b[15], out=px0x15); And(a=a[1], b=b[15], out=px1x15); And(a=a[2], b=b[15], out=px2x15); And(a=a[3], b=b[15], out=px3x15);
    And(a=a[4], b=b[15], out=px4x15); And(a=a[5], b=b[15], out=px5x15); And(a=a[6], b=b[15], out=px6x15); And(a=a[7], b=b[15], out=px7x15);
    And(a=a[8], b=b[15], out=px8x15); And(a=a[9], b=b[15], out=px9x15); And(a=a[10], b=b[15], out=px10x15); And(a=a[11], b=b[15], out=px11x15);
    And(a=a[12], b=b[15], out=px12x15); And(a=a[13], b=b[15], out=px13x15); And(a=a[14], b=b[15], out=px14x15); And(a=a[15], b=b[15], out=px15x15);


    
    // Stage 1: 16 rows -> 11 rows
    
    // Grp A (Rows 0,1,2 - weights 0 to 17)
    Or(a=px0x0, b=false, out=sAx0);
    HalfAdder(a=px1x0, b=px0x1, sum=sAx1, carry=cAx2);
    FullAdder(a=px2x0, b=px1x1, c=px0x2, sum=sAx2, carry=cAx3);
    FullAdder(a=px3x0, b=px2x1, c=px1x2, sum=sAx3, carry=cAx4);
    FullAdder(a=px4x0, b=px3x1, c=px2x2, sum=sAx4, carry=cAx5);
    FullAdder(a=px5x0, b=px4x1, c=px3x2, sum=sAx5, carry=cAx6);
    FullAdder(a=px6x0, b=px5x1, c=px4x2, sum=sAx6, carry=cAx7);
    FullAdder(a=px7x0, b=px6x1, c=px5x2, sum=sAx7, carry=cAx8);
    FullAdder(a=px8x0, b=px7x1, c=px6x2, sum=sAx8, carry=cAx9);
    FullAdder(a=px9x0, b=px8x1, c=px7x2, sum=sAx9, carry=cAx10);
    FullAdder(a=px10x0, b=px9x1, c=px8x2, sum=sAx10, carry=cAx11);
    FullAdder(a=px11x0, b=px10x1, c=px9x2, sum=sAx11, carry=cAx12);
    FullAdder(a=px12x0, b=px11x1, c=px10x2, sum=sAx12, carry=cAx13);
    FullAdder(a=px13x0, b=px12x1, c=px11x2, sum=sAx13, carry=cAx14);
    FullAdder(a=px14x0, b=px13x1, c=px12x2, sum=sAx14, carry=cAx15);
    FullAdder(a=px15x0, b=px14x1, c=px13x2, sum=sAx15, carry=cAx16);
    HalfAdder(a=px15x1, b=px14x2, sum=sAx16, carry=cAx17);
    Or(a=px15x2, b=false, out=sAx17);

    // Grp B (Rows 3,4,5 - weights 3 to 20)
    Or(a=px0x3, b=false, out=sBx3);
    HalfAdder(a=px1x3, b=px0x4, sum=sBx4, carry=cBx5);
    FullAdder(a=px2x3, b=px1x4, c=px0x5, sum=sBx5, carry=cBx6);
    FullAdder(a=px3x3, b=px2x4, c=px1x5, sum=sBx6, carry=cBx7);
