    FullAdder(a=cGx22, b=sHx22, c=cHx22, sum=sKx22, carry=cKx23);
    FullAdder(a=cGx23, b=sHx23, c=cHx23, sum=sKx23, carry=cKx24);
    FullAdder(a=cGx24, b=sHx24, c=cHx24, sum=sKx24, carry=cKx25);
    HalfAdder(a=sHx25, b=cHx25, sum=sKx25, carry=cKx26);
    HalfAdder(a=sHx26, b=cHx26, sum=sKx26, carry=cKx27);
    HalfAdder(a=sHx27, b=cHx27, sum=sKx27, carry=cKx28);
    Or(a=sHx28, b=false, out=sKx28);
    Or(a=sHx29, b=false, out=sKx29);


    
    // Stage 4: 6 rows -> 4 rows
    
    // Grp L (sJ:0..23, cJ:4..21, sK:7..29)
    Or(a=sJx0, b=false, out=sLx0); Or(a=sJx1, b=false, out=sLx1);
    Or(a=sJx2, b=false, out=sLx2); Or(a=sJx3, b=false, out=sLx3);
    HalfAdder(a=sJx4, b=cJx4, sum=sLx4, carry=cLx5);
    HalfAdder(a=sJx5, b=cJx5, sum=sLx5, carry=cLx6);
    HalfAdder(a=sJx6, b=cJx6, sum=sLx6, carry=cLx7);
    FullAdder(a=sJx7, b=cJx7, c=sKx7, sum=sLx7, carry=cLx8);
