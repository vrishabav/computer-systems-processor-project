    HalfAdder(a=px15x10, b=px14x11, sum=sDx25, carry=cDx26);
    Or(a=px15x11, b=false, out=sDx26);

    // Grp E (Rows 12,13,14 - weights 12 to 29)
    Or(a=px0x12, b=false, out=sEx12);
    HalfAdder(a=px1x12, b=px0x13, sum=sEx13, carry=cEx14);
    FullAdder(a=px2x12, b=px1x13, c=px0x14, sum=sEx14, carry=cEx15);
    FullAdder(a=px3x12, b=px2x13, c=px1x14, sum=sEx15, carry=cEx16);
    FullAdder(a=px4x12, b=px3x13, c=px2x14, sum=sEx16, carry=cEx17);
    FullAdder(a=px5x12, b=px4x13, c=px3x14, sum=sEx17, carry=cEx18);
    FullAdder(a=px6x12, b=px5x13, c=px4x14, sum=sEx18, carry=cEx19);
    FullAdder(a=px7x12, b=px6x13, c=px5x14, sum=sEx19, carry=cEx20);
