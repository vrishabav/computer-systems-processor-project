    HalfAdder(a=sFx20, b=sGx20, sum=sJx20, carry=cJx21);
    Or(a=sGx21, b=false, out=sJx21);
    Or(a=sGx22, b=false, out=sJx22);
    Or(a=sGx23, b=false, out=sJx23);

    // Grp K (cG:7..24, sH:9..29, cH:12..27)
    Or(a=cGx7, b=false, out=sKx7);
    Or(a=cGx8, b=false, out=sKx8);
    HalfAdder(a=cGx9, b=sHx9, sum=sKx9, carry=cKx10);
