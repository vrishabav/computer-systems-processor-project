    FullAdder(a=cGx13, b=sHx13, c=cHx13, sum=sKx13, carry=cKx14);
    FullAdder(a=cGx14, b=sHx14, c=cHx14, sum=sKx14, carry=cKx15);
    FullAdder(a=cGx15, b=sHx15, c=cHx15, sum=sKx15, carry=cKx16);
