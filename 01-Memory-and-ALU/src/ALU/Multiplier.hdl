    FullAdder(a=px8x6, b=px7x7, c=px6x8, sum=sCx14, carry=cCx15);
    FullAdder(a=px9x6, b=px8x7, c=px7x8, sum=sCx15, carry=cCx16);
    FullAdder(a=px10x6, b=px9x7, c=px8x8, sum=sCx16, carry=cCx17);
    FullAdder(a=px11x6, b=px10x7, c=px9x8, sum=sCx17, carry=cCx18);
    FullAdder(a=px12x6, b=px11x7, c=px10x8, sum=sCx18, carry=cCx19);
    FullAdder(a=px13x6, b=px12x7, c=px11x8, sum=sCx19, carry=cCx20);
    FullAdder(a=px14x6, b=px13x7, c=px12x8, sum=sCx20, carry=cCx21);
