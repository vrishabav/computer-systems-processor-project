    FullAdder(a=px14x12, b=px13x13, c=px12x14, sum=sEx26, carry=cEx27);
    FullAdder(a=px15x12, b=px14x13, c=px13x14, sum=sEx27, carry=cEx28);
    HalfAdder(a=px15x13, b=px14x14, sum=sEx28, carry=cEx29);
    Or(a=px15x14, b=false, out=sEx29);

    // Row 15 Forwarding
    Or(a=px0x15, b=false, out=sPx15); Or(a=px1x15, b=false, out=sPx16); Or(a=px2x15, b=false, out=sPx17); Or(a=px3x15, b=false, out=sPx18);
    Or(a=px4x15, b=false, out=sPx19); Or(a=px5x15, b=false, out=sPx20); Or(a=px6x15, b=false, out=sPx21); Or(a=px7x15, b=false, out=sPx22);
    Or(a=px8x15, b=false, out=sPx23); Or(a=px9x15, b=false, out=sPx24); Or(a=px10x15, b=false, out=sPx25); Or(a=px11x15, b=false, out=sPx26);
    Or(a=px12x15, b=false, out=sPx27); Or(a=px13x15, b=false, out=sPx28); Or(a=px14x15, b=false, out=sPx29); Or(a=px15x15, b=false, out=sPx30);


    
    // Stage 2: 11 rows -> 8 rows
    
    // Grp F (sA:0..17, cA:2..17, sB:3..20)
    Or(a=sAx0, b=false, out=sFx0);
    Or(a=sAx1, b=false, out=sFx1);
    HalfAdder(a=sAx2, b=cAx2, sum=sFx2, carry=cFx3);
    FullAdder(a=sAx3, b=cAx3, c=sBx3, sum=sFx3, carry=cFx4);
    FullAdder(a=sAx4, b=cAx4, c=sBx4, sum=sFx4, carry=cFx5);
    FullAdder(a=sAx5, b=cAx5, c=sBx5, sum=sFx5, carry=cFx6);
    FullAdder(a=sAx6, b=cAx6, c=sBx6, sum=sFx6, carry=cFx7);
    FullAdder(a=sAx7, b=cAx7, c=sBx7, sum=sFx7, carry=cFx8);
    FullAdder(a=sAx8, b=cAx8, c=sBx8, sum=sFx8, carry=cFx9);
    FullAdder(a=sAx9, b=cAx9, c=sBx9, sum=sFx9, carry=cFx10);
    FullAdder(a=sAx10, b=cAx10, c=sBx10, sum=sFx10, carry=cFx11);
    FullAdder(a=sAx11, b=cAx11, c=sBx11, sum=sFx11, carry=cFx12);
    FullAdder(a=sAx12, b=cAx12, c=sBx12, sum=sFx12, carry=cFx13);
