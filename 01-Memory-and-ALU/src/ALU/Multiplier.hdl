    FullAdder(a=cKx25, b=cEx25, c=sPx25, sum=sMx25, carry=cMx26);
    FullAdder(a=cKx26, b=cEx26, c=sPx26, sum=sMx26, carry=cMx27);
    FullAdder(a=cKx27, b=cEx27, c=sPx27, sum=sMx27, carry=cMx28);
    FullAdder(a=cKx28, b=cEx28, c=sPx28, sum=sMx28, carry=cMx29);
    HalfAdder(a=cEx29, b=sPx29, sum=sMx29, carry=cMx30);
    Or(a=sPx30, b=false, out=sMx30);


    
    // Stage 5: 4 rows -> 3 rows
    
    // Grp N (sL:0..29, cL:5..24, sM:10..30)
    Or(a=sLx0, b=false, out=sNx0); Or(a=sLx1, b=false, out=sNx1); Or(a=sLx2, b=false, out=sNx2);
    Or(a=sLx3, b=false, out=sNx3); Or(a=sLx4, b=false, out=sNx4);
    HalfAdder(a=sLx5, b=cLx5, sum=sNx5, carry=cNx6);
    HalfAdder(a=sLx6, b=cLx6, sum=sNx6, carry=cNx7);
    HalfAdder(a=sLx7, b=cLx7, sum=sNx7, carry=cNx8);
    HalfAdder(a=sLx8, b=cLx8, sum=sNx8, carry=cNx9);
    HalfAdder(a=sLx9, b=cLx9, sum=sNx9, carry=cNx10);
    FullAdder(a=sLx10, b=cLx10, c=sMx10, sum=sNx10, carry=cNx11);
    FullAdder(a=sLx11, b=cLx11, c=sMx11, sum=sNx11, carry=cNx12);
    FullAdder(a=sLx12, b=cLx12, c=sMx12, sum=sNx12, carry=cNx13);
    FullAdder(a=sLx13, b=cLx13, c=sMx13, sum=sNx13, carry=cNx14);
    FullAdder(a=sLx14, b=cLx14, c=sMx14, sum=sNx14, carry=cNx15);
    FullAdder(a=sLx15, b=cLx15, c=sMx15, sum=sNx15, carry=cNx16);
    FullAdder(a=sLx16, b=cLx16, c=sMx16, sum=sNx16, carry=cNx17);
    FullAdder(a=sLx17, b=cLx17, c=sMx17, sum=sNx17, carry=cNx18);
    FullAdder(a=sLx18, b=cLx18, c=sMx18, sum=sNx18, carry=cNx19);
    FullAdder(a=sLx19, b=cLx19, c=sMx19, sum=sNx19, carry=cNx20);
    FullAdder(a=sLx20, b=cLx20, c=sMx20, sum=sNx20, carry=cNx21);
    FullAdder(a=sLx21, b=cLx21, c=sMx21, sum=sNx21, carry=cNx22);
    FullAdder(a=sLx22, b=cLx22, c=sMx22, sum=sNx22, carry=cNx23);
    FullAdder(a=sLx23, b=cLx23, c=sMx23, sum=sNx23, carry=cNx24);
    FullAdder(a=sLx24, b=cLx24, c=sMx24, sum=sNx24, carry=cNx25);
    HalfAdder(a=sLx25, b=sMx25, sum=sNx25, carry=cNx26);
    HalfAdder(a=sLx26, b=sMx26, sum=sNx26, carry=cNx27);
    HalfAdder(a=sLx27, b=sMx27, sum=sNx27, carry=cNx28);
    HalfAdder(a=sLx28, b=sMx28, sum=sNx28, carry=cNx29);
    HalfAdder(a=sLx29, b=sMx29, sum=sNx29, carry=cNx30);
    Or(a=sMx30, b=false, out=sNx30);


    
    // Stage 6: 3 rows -> 2 rows
    
    // Grp O (sN:0..30, cN:6..30, cM:15..30)
    Or(a=sNx0, b=false, out=sOx0); Or(a=sNx1, b=false, out=sOx1); Or(a=sNx2, b=false, out=sOx2);
    Or(a=sNx3, b=false, out=sOx3); Or(a=sNx4, b=false, out=sOx4); Or(a=sNx5, b=false, out=sOx5);
    HalfAdder(a=sNx6, b=cNx6, sum=sOx6, carry=cOx7);
    HalfAdder(a=sNx7, b=cNx7, sum=sOx7, carry=cOx8);
    HalfAdder(a=sNx8, b=cNx8, sum=sOx8, carry=cOx9);
    HalfAdder(a=sNx9, b=cNx9, sum=sOx9, carry=cOx10);
    HalfAdder(a=sNx10, b=cNx10, sum=sOx10, carry=cOx11);
    HalfAdder(a=sNx11, b=cNx11, sum=sOx11, carry=cOx12);
    HalfAdder(a=sNx12, b=cNx12, sum=sOx12, carry=cOx13);
    HalfAdder(a=sNx13, b=cNx13, sum=sOx13, carry=cOx14);
    HalfAdder(a=sNx14, b=cNx14, sum=sOx14, carry=cOx15);
    FullAdder(a=sNx15, b=cNx15, c=cMx15, sum=sOx15, carry=cOx16);
    FullAdder(a=sNx16, b=cNx16, c=cMx16, sum=sOx16, carry=cOx17);
    FullAdder(a=sNx17, b=cNx17, c=cMx17, sum=sOx17, carry=cOx18);
    FullAdder(a=sNx18, b=cNx18, c=cMx18, sum=sOx18, carry=cOx19);
    FullAdder(a=sNx19, b=cNx19, c=cMx19, sum=sOx19, carry=cOx20);
    FullAdder(a=sNx20, b=cNx20, c=cMx20, sum=sOx20, carry=cOx21);
    FullAdder(a=sNx21, b=cNx21, c=cMx21, sum=sOx21, carry=cOx22);
    FullAdder(a=sNx22, b=cNx22, c=cMx22, sum=sOx22, carry=cOx23);
    FullAdder(a=sNx23, b=cNx23, c=cMx23, sum=sOx23, carry=cOx24);
    FullAdder(a=sNx24, b=cNx24, c=cMx24, sum=sOx24, carry=cOx25);
    FullAdder(a=sNx25, b=cNx25, c=cMx25, sum=sOx25, carry=cOx26);
    FullAdder(a=sNx26, b=cNx26, c=cMx26, sum=sOx26, carry=cOx27);
    FullAdder(a=sNx27, b=cNx27, c=cMx27, sum=sOx27, carry=cOx28);
    FullAdder(a=sNx28, b=cNx28, c=cMx28, sum=sOx28, carry=cOx29);
    FullAdder(a=sNx29, b=cNx29, c=cMx29, sum=sOx29, carry=cOx30);
    FullAdder(a=sNx30, b=cNx30, c=cMx30, sum=sOx30, carry=cOx31);



    
    // Final Addition: 4-bit CLA
    // sO[0..30] + cO[7..31] -> c[0..31]
    

    // bits 0-6: only sO, no cO at these weights
    Or(a=sOx0, b=false, out=c[0]);
    Or(a=sOx1, b=false, out=c[1]);
    Or(a=sOx2, b=false, out=c[2]);
    Or(a=sOx3, b=false, out=c[3]);
    Or(a=sOx4, b=false, out=c[4]);
    Or(a=sOx5, b=false, out=c[5]);
    Or(a=sOx6, b=false, out=c[6]);

    // bit 7: first position where cO exists, no carry in
    HalfAdder(a=sOx7, b=cOx7, sum=c[7], carry=cy8);

    // bits 8-11 (carry in: cy8)
    And(a=sOx8, b=cOx8, out=g8); Xor(a=sOx8, b=cOx8, out=p8);
    And(a=sOx9, b=cOx9, out=g9); Xor(a=sOx9, b=cOx9, out=p9);
    And(a=sOx10, b=cOx10, out=g10); Xor(a=sOx10, b=cOx10, out=p10);
    And(a=sOx11, b=cOx11, out=g11); Xor(a=sOx11, b=cOx11, out=p11);
    And(a=p8, b=cy8, out=t8a);
    Or(a=g8, b=t8a, out=c9);
    And(a=p9, b=g8, out=t8b); And(a=p9, b=p8, out=t8c); And(a=t8c, b=cy8, out=t8d);
    Or(a=g9, b=t8b, out=t8e); Or(a=t8e, b=t8d, out=c10);
    And(a=p10, b=g9, out=t8f); And(a=p10, b=p9, out=t8g);
    And(a=t8g, b=g8, out=t8h); And(a=t8g, b=p8, out=t8i); And(a=t8i, b=cy8, out=t8j);
    Or(a=g10, b=t8f, out=t8k); Or(a=t8k, b=t8h, out=t8l); Or(a=t8l, b=t8j, out=c11);
    And(a=p11, b=g10, out=t8m); And(a=p11, b=p10, out=t8n);
    And(a=t8n, b=g9, out=t8o); And(a=t8n, b=p9, out=t8p);
    And(a=t8p, b=g8, out=t8q); And(a=t8p, b=p8, out=t8r); And(a=t8r, b=cy8, out=t8s);
    Or(a=g11, b=t8m, out=t8u); Or(a=t8u, b=t8o, out=t8v); Or(a=t8v, b=t8q, out=t8w); Or(a=t8w, b=t8s, out=cy12);
    Xor(a=p8, b=cy8, out=c[8]);
    Xor(a=p9, b=c9, out=c[9]);
    Xor(a=p10, b=c10, out=c[10]);
    Xor(a=p11, b=c11, out=c[11]);

    // bits 12-15 (carry in: cy12)
    And(a=sOx12, b=cOx12, out=g12); Xor(a=sOx12, b=cOx12, out=p12);
    And(a=sOx13, b=cOx13, out=g13); Xor(a=sOx13, b=cOx13, out=p13);
    And(a=sOx14, b=cOx14, out=g14); Xor(a=sOx14, b=cOx14, out=p14);
    And(a=sOx15, b=cOx15, out=g15); Xor(a=sOx15, b=cOx15, out=p15);
    And(a=p12, b=cy12, out=t12a);
    Or(a=g12, b=t12a, out=c13);
    And(a=p13, b=g12, out=t12b); And(a=p13, b=p12, out=t12c); And(a=t12c, b=cy12, out=t12d);
    Or(a=g13, b=t12b, out=t12e); Or(a=t12e, b=t12d, out=c14);
    And(a=p14, b=g13, out=t12f); And(a=p14, b=p13, out=t12g);
    And(a=t12g, b=g12, out=t12h); And(a=t12g, b=p12, out=t12i); And(a=t12i, b=cy12, out=t12j);
    Or(a=g14, b=t12f, out=t12k); Or(a=t12k, b=t12h, out=t12l); Or(a=t12l, b=t12j, out=c15);
    And(a=p15, b=g14, out=t12m); And(a=p15, b=p14, out=t12n);
    And(a=t12n, b=g13, out=t12o); And(a=t12n, b=p13, out=t12p);
    And(a=t12p, b=g12, out=t12q); And(a=t12p, b=p12, out=t12r); And(a=t12r, b=cy12, out=t12s);
    Or(a=g15, b=t12m, out=t12u); Or(a=t12u, b=t12o, out=t12v); Or(a=t12v, b=t12q, out=t12w); Or(a=t12w, b=t12s, out=cy16);
    Xor(a=p12, b=cy12, out=c[12]);
    Xor(a=p13, b=c13, out=c[13]);
    Xor(a=p14, b=c14, out=c[14]);
    Xor(a=p15, b=c15, out=c[15]);

    // bits 16-19 (carry in: cy16)
    And(a=sOx16, b=cOx16, out=g16); Xor(a=sOx16, b=cOx16, out=p16);
    And(a=sOx17, b=cOx17, out=g17); Xor(a=sOx17, b=cOx17, out=p17);
    And(a=sOx18, b=cOx18, out=g18); Xor(a=sOx18, b=cOx18, out=p18);
    And(a=sOx19, b=cOx19, out=g19); Xor(a=sOx19, b=cOx19, out=p19);
    And(a=p16, b=cy16, out=t16a);
    Or(a=g16, b=t16a, out=c17);
    And(a=p17, b=g16, out=t16b); And(a=p17, b=p16, out=t16c); And(a=t16c, b=cy16, out=t16d);
    Or(a=g17, b=t16b, out=t16e); Or(a=t16e, b=t16d, out=c18);
    And(a=p18, b=g17, out=t16f); And(a=p18, b=p17, out=t16g);
    And(a=t16g, b=g16, out=t16h); And(a=t16g, b=p16, out=t16i); And(a=t16i, b=cy16, out=t16j);
    Or(a=g18, b=t16f, out=t16k); Or(a=t16k, b=t16h, out=t16l); Or(a=t16l, b=t16j, out=c19);
    And(a=p19, b=g18, out=t16m); And(a=p19, b=p18, out=t16n);
    And(a=t16n, b=g17, out=t16o); And(a=t16n, b=p17, out=t16p);
    And(a=t16p, b=g16, out=t16q); And(a=t16p, b=p16, out=t16r); And(a=t16r, b=cy16, out=t16s);
    Or(a=g19, b=t16m, out=t16u); Or(a=t16u, b=t16o, out=t16v); Or(a=t16v, b=t16q, out=t16w); Or(a=t16w, b=t16s, out=cy20);
    Xor(a=p16, b=cy16, out=c[16]);
    Xor(a=p17, b=c17, out=c[17]);
    Xor(a=p18, b=c18, out=c[18]);
    Xor(a=p19, b=c19, out=c[19]);

    // bits 20-23 (carry in: cy20)
    And(a=sOx20, b=cOx20, out=g20); Xor(a=sOx20, b=cOx20, out=p20);
    And(a=sOx21, b=cOx21, out=g21); Xor(a=sOx21, b=cOx21, out=p21);
    And(a=sOx22, b=cOx22, out=g22); Xor(a=sOx22, b=cOx22, out=p22);
    And(a=sOx23, b=cOx23, out=g23); Xor(a=sOx23, b=cOx23, out=p23);
    And(a=p20, b=cy20, out=t20a);
    Or(a=g20, b=t20a, out=c21);
    And(a=p21, b=g20, out=t20b); And(a=p21, b=p20, out=t20c); And(a=t20c, b=cy20, out=t20d);
    Or(a=g21, b=t20b, out=t20e); Or(a=t20e, b=t20d, out=c22);
    And(a=p22, b=g21, out=t20f); And(a=p22, b=p21, out=t20g);
    And(a=t20g, b=g20, out=t20h); And(a=t20g, b=p20, out=t20i); And(a=t20i, b=cy20, out=t20j);
    Or(a=g22, b=t20f, out=t20k); Or(a=t20k, b=t20h, out=t20l); Or(a=t20l, b=t20j, out=c23);
    And(a=p23, b=g22, out=t20m); And(a=p23, b=p22, out=t20n);
    And(a=t20n, b=g21, out=t20o); And(a=t20n, b=p21, out=t20p);
    And(a=t20p, b=g20, out=t20q); And(a=t20p, b=p20, out=t20r); And(a=t20r, b=cy20, out=t20s);
    Or(a=g23, b=t20m, out=t20u); Or(a=t20u, b=t20o, out=t20v); Or(a=t20v, b=t20q, out=t20w); Or(a=t20w, b=t20s, out=cy24);
    Xor(a=p20, b=cy20, out=c[20]);
    Xor(a=p21, b=c21, out=c[21]);
    Xor(a=p22, b=c22, out=c[22]);
    Xor(a=p23, b=c23, out=c[23]);

    // bits 24-27 (carry in: cy24)
    And(a=sOx24, b=cOx24, out=g24); Xor(a=sOx24, b=cOx24, out=p24);
    And(a=sOx25, b=cOx25, out=g25); Xor(a=sOx25, b=cOx25, out=p25);
    And(a=sOx26, b=cOx26, out=g26); Xor(a=sOx26, b=cOx26, out=p26);
    And(a=sOx27, b=cOx27, out=g27); Xor(a=sOx27, b=cOx27, out=p27);
    And(a=p24, b=cy24, out=t24a);
    Or(a=g24, b=t24a, out=c25);
    And(a=p25, b=g24, out=t24b); And(a=p25, b=p24, out=t24c); And(a=t24c, b=cy24, out=t24d);
    Or(a=g25, b=t24b, out=t24e); Or(a=t24e, b=t24d, out=c26);
    And(a=p26, b=g25, out=t24f); And(a=p26, b=p25, out=t24g);
    And(a=t24g, b=g24, out=t24h); And(a=t24g, b=p24, out=t24i); And(a=t24i, b=cy24, out=t24j);
    Or(a=g26, b=t24f, out=t24k); Or(a=t24k, b=t24h, out=t24l); Or(a=t24l, b=t24j, out=c27);
    And(a=p27, b=g26, out=t24m); And(a=p27, b=p26, out=t24n);
    And(a=t24n, b=g25, out=t24o); And(a=t24n, b=p25, out=t24p);
    And(a=t24p, b=g24, out=t24q); And(a=t24p, b=p24, out=t24r); And(a=t24r, b=cy24, out=t24s);
    Or(a=g27, b=t24m, out=t24u); Or(a=t24u, b=t24o, out=t24v); Or(a=t24v, b=t24q, out=t24w); Or(a=t24w, b=t24s, out=cy28);
    Xor(a=p24, b=cy24, out=c[24]);
    Xor(a=p25, b=c25, out=c[25]);
    Xor(a=p26, b=c26, out=c[26]);
    Xor(a=p27, b=c27, out=c[27]);

    // bits 28-31 (bit 31: no sOx31, g31=0, p31=cOx31)
    And(a=sOx28, b=cOx28, out=g28); Xor(a=sOx28, b=cOx28, out=p28);
    And(a=sOx29, b=cOx29, out=g29); Xor(a=sOx29, b=cOx29, out=p29);
    And(a=sOx30, b=cOx30, out=g30); Xor(a=sOx30, b=cOx30, out=p30);
    And(a=p28, b=cy28, out=t28a);
    Or(a=g28, b=t28a, out=c29);
    And(a=p29, b=g28, out=t28b); And(a=p29, b=p28, out=t28c); And(a=t28c, b=cy28, out=t28d);
    Or(a=g29, b=t28b, out=t28e); Or(a=t28e, b=t28d, out=c30);
    And(a=p30, b=g29, out=t28f); And(a=p30, b=p29, out=t28g);
    And(a=t28g, b=g28, out=t28h); And(a=t28g, b=p28, out=t28i); And(a=t28i, b=cy28, out=t28j);
    Or(a=g30, b=t28f, out=t28k); Or(a=t28k, b=t28h, out=t28l); Or(a=t28l, b=t28j, out=c31);
    Xor(a=p28, b=cy28, out=c[28]);
    Xor(a=p29, b=c29, out=c[29]);
    Xor(a=p30, b=c30, out=c[30]);
    Xor(a=cOx31, b=c31, out=c[31]);
}
